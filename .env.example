# ==========================================
# 🚀 DATABASE
# ==========================================
# Neon DB (production) — ganti dengan connection string Neon-mu
# DATABASE_URL="postgresql://user:password@host:port/db?sslmode=require"
# DIRECT_URL="postgresql://user:password@host:port/db?sslmode=require"

# Local PostgreSQL (development)
# DATABASE_URL="postgresql://user@localhost:5432/db_name?schema=public"
# DIRECT_URL="postgresql://user@localhost:5432/db_name?schema=public"

# ==========================================
# 🔐 AUTH & SERVICES
# ==========================================
# Generate dengan: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# Password default untuk seed akun admin
ADMIN_SEED_PASSWORD="your-admin-password"

# Vercel Blob (untuk upload gambar produk/QRIS)
# BLOB_STORE_ID="your-blob-store-id"
# BLOB_READ_WRITE_TOKEN="your-blob-token"
